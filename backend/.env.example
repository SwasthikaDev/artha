# Copy to .env and fill in. Both are OPTIONAL — the app runs fully with seeded
# fallbacks if these are absent.

# Live market data (AlphaVantage free tier: https://www.alphavantage.co/support/#api-key)
ALPHAVANTAGE_API_KEY=

# AI advisor (Anthropic Claude). If absent, a rule-based advisor is used.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5
